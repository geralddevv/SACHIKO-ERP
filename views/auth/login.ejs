<% layout('/layout/auth') -%>

<section class="login-shell" data-brand="sachiko">
  <div class="login-accent"></div>
  <div class="login-card">

    <div class="login-header">
      <div class="login-mark">
        <img src="/assets/sachikofavicon.png" alt="Sachiko" />
      </div>
      <div>
        <h2>Sachiko Packaging</h2>
        <p>Secure access for Sachiko Packaging</p>
      </div>
    </div>

  <% if (typeof error !== 'undefined' && error.length) { %>
    <div class="login-alert">
      <i class="fa-solid fa-circle-exclamation"></i>
      <span><%= error[0] %></span>
    </div>
  <% } %>

    <form class="login-form" action="/sachiko/login" method="post" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label for="login-profile-code">Profile Code</label>
      <input
        id="login-profile-code"
        name="profileCode"
        type="text"
        class="form-control"
        placeholder="Enter your profile code"
        value="<%= typeof profileCode !== 'undefined' ? profileCode : '' %>"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        readonly
        required
      />
      <label for="login-password">Password</label>
      <div class="password-field">
        <input
          id="login-password"
          name="password"
          type="password"
          class="form-control"
          placeholder="Enter your password"
          value="<%= typeof password !== 'undefined' ? password : '' %>"
          autocomplete="new-password"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          readonly
          required
        />
        <button class="password-toggle" type="button" id="togglePassword" aria-label="Show password">
          <i class="fa-regular fa-eye" aria-hidden="true"></i>
        </button>
      </div>
      <button class="btn btn-primary w-100 login-submit" type="submit">
        Sign in
        <i class="fa-solid fa-arrow-right"></i>
      </button>
    </form>

    <p class="login-help">Need access? Contact your system administrator.</p>
  </div>
</section>

<script>
  (function () {
    // Block browser/password-manager autofill on page load.
    // Fields are rendered with `readonly`, which autofill skips; we clear it
    // the instant the user actually interacts with the field.
    const guarded = document.querySelectorAll('.login-form input[readonly]');
    guarded.forEach((el) => {
      const unlock = () => el.removeAttribute("readonly");
      el.addEventListener("focus", unlock, { once: true });
      el.addEventListener("pointerdown", unlock, { once: true });
    });

    // Suppress Chrome's "Save password?" prompt. Just before the form
    // navigates, replace the password field with a plain hidden input that
    // carries the same value. With no enabled `type="password"` control left
    // in the form, the browser's password manager has no credential to offer
    // to save. The value still reaches the server under `name="password"`.
    const form = document.querySelector(".login-form");
    if (form) {
      form.addEventListener("submit", () => {
        const pw = document.getElementById("login-password");
        if (!pw) return;
        const hidden = document.createElement("input");
        hidden.type = "hidden";
        hidden.name = pw.name || "password";
        hidden.value = pw.value;
        pw.removeAttribute("name");
        pw.disabled = true;
        form.appendChild(hidden);
      });
    }
  })();

  (function () {
    const toggle = document.getElementById("togglePassword");
    const input = document.getElementById("login-password");
    if (!toggle || !input) return;

    toggle.addEventListener("click", () => {
      const isPassword = input.type === "password";
      input.type = isPassword ? "text" : "password";
      toggle.setAttribute("aria-label", isPassword ? "Hide password" : "Show password");
      toggle.innerHTML = isPassword
        ? '<i class="fa-regular fa-eye-slash" aria-hidden="true"></i>'
        : '<i class="fa-regular fa-eye" aria-hidden="true"></i>';
    });
  })();
</script>
